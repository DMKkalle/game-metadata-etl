# Twitch / IGDB API credentials
# Get yours at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# GiantBomb API key
# Get yours at: https://www.giantbomb.com/api/
GIANTBOMB_API_KEY=your_giantbomb_api_key_here
GB_USER_AGENT=YourAppName/1.0 (contact: your@email.com)
